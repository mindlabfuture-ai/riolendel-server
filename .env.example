# Copy this file to .env for local development.
# On Railway, set these under your service's Variables tab instead —
# never commit a real .env file to GitHub.

# Get a free key at https://www.goldapi.io (Google sign-in, no card required)
GOLDAPI_KEY=

# Railway sets this automatically once you attach a Postgres plugin.
# Leave blank locally if you don't have Postgres running — the app
# will still work, just without saving opt-ins.
DATABASE_URL=

# Cron schedule for the gold price fetch. Default: once daily at 01:00 UTC.
# Keep this to 1-2 runs/day max — GoldAPI's free plan allows ~100 requests/month.
GOLD_PRICE_CRON=0 1 * * *

PORT=3000

# --- AI features (chatbot + lead agent) ---
# Get an API key at https://console.anthropic.com (pay-as-you-go, needs a card).
# The chatbot and email drafting use claude-haiku-4-5 ($1/$5 per million
# input/output tokens) with tight caps — typical cost is cents per day at
# low traffic, but set a spend limit in the Anthropic console to be safe.
ANTHROPIC_API_KEY=

# Any long random string. Protects /api/admin/lead-report AND the
# video scraper + affiliate product manager at /admin/videos.html.
# Generate one with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_TOKEN=

# --- Cross-platform social posting ---
# Two ways to post to each platform. Buffer is checked first per-channel;
# if a channel isn't set up in Buffer, the raw platform API is used as
# a fallback (if configured). Unconfigured channels fall back further
# to "copy text" mode. Admin dashboard: /admin/social.html

# BUFFER (recommended) — one API, official partner for FB/IG/TikTok,
# so you skip Meta App Review and TikTok Developer approval entirely.
# 1. Sign up at buffer.com, connect Facebook/Instagram/TikTok as channels.
# 2. Buffer dashboard → Settings → API → generate a personal API key
#    (must be an organization owner).
# 3. Deploy this app, then hit this once to find your IDs:
#    GET https://riolendel.com/api/admin/buffer/channels?token=YOUR_ADMIN_TOKEN
#    It returns your organizationId and each connected channel's id.
# 4. Fill in the values below from that response.
BUFFER_API_KEY=
BUFFER_ORGANIZATION_ID=
BUFFER_CHANNEL_FACEBOOK=
BUFFER_CHANNEL_INSTAGRAM=
BUFFER_CHANNEL_TIKTOK=

# --- Raw platform APIs (fallback if a channel isn't set up in Buffer) ---

# FACEBOOK — Post to your FB Page via Graph API.
# 1. Create a Meta Developer App at developers.facebook.com
# 2. Add "Pages" product, get a Page Access Token with pages_manage_posts permission
# 3. Extend to a long-lived (non-expiring) Page token via the Token Debugger
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# INSTAGRAM — Post via Meta's Instagram Graph API (same Meta App).
# Requires: IG Business or Creator account linked to your FB Page,
# instagram_basic + instagram_content_publish permissions (needs Meta App Review).
IG_USER_ID=
IG_ACCESS_TOKEN=

# TIKTOK — Content Posting API.
# 1. Register at developers.tiktok.com, create app, request Content Posting scope
# 2. TikTok manually reviews (days–weeks). OAuth per account.
# 3. For now, the dashboard provides "copy text" fallback until approved.
TIKTOK_ACCESS_TOKEN=

# SHOPEE — No public social posting API. Always manual copy-paste.
# (No env var needed.)

# --- AI video generation (Runway) ---
# Turns a single product photo into a short showcase video, instead of
# reposting scraped Shopee/TikTok videos (which carry platform
# watermarks — bad for cross-posting). Admin dashboard:
# /admin/videos.html -> Warm-Up & Schedule tab -> Option B
# ("Product Shot Video Builder"): pick a locked-product shot preset
# (orbit / zoom / light sweep / tilt) — each explicitly instructs the
# model to keep the product fixed and only move the camera/lighting.
# This reduces but does NOT eliminate the risk of the product itself
# coming out subtly altered — always use the built-in side-by-side
# comparison (original photo vs. generated frame) before posting.
#
# 1. Sign up at runwayml.com/api (the DEVELOPER portal — separate
#    account/billing from a regular consumer Runway subscription).
# 2. Go to Settings > API in that developer portal, create an API key.
# 3. Fund API credits from that SAME developer portal's billing page
#    ($0.01/credit, minimum 1,000-credit purchase) — a regular Runway
#    web-app subscription plan does NOT fund API usage; they are
#    completely separate balances.
# 4. Set RUNWAY_API_KEY below.
# 5. SITE_URL must be your real public domain (not localhost) — Runway
#    fetches the uploaded product photo from a URL, so it needs to be
#    reachable from Runway's servers, not just your own machine.
#
# NOTE: this was built without live access to test against Runway's
# current API, since exact field names/enums can shift between model
# versions (Gen-3 -> Gen-4 -> Gen-4.5). If generation fails with a
# schema/field error, check https://docs.dev.runwayml.com and adjust
# src/videoGenerator.js's createTask() request shape to match.
RUNWAY_API_KEY=
# Non-Turbo model by default — better product fidelity, Turbo trades
# quality for speed/cost. Switch to gen4_turbo only after confirming
# gen4's accuracy is good enough that the cheaper/faster option is
# also acceptable for your products.
RUNWAY_MODEL=gen4
# Runway's API versioning header — bump if their docs show a newer date.
RUNWAY_API_VERSION=2024-11-06
# Output video aspect ratio, in Runway's "WIDTHxHEIGHT" pixel format.
RUNWAY_RATIO=1280:720
# Clip length in seconds — kept short (was 5, now 4) since shorter
# generations give the model less time to drift away from the source
# product image.
RUNWAY_DURATION=4

# --- Warm-up campaigns & scheduling ---
# Requires ffmpeg + ffprobe on the host for JPEG frame extraction from
# uploaded videos (and from videos fetched via the Shopee link
# downloader — same ffmpeg dependency, no separate setup). Already
# present in this container; on Railway, add a nixpacks.toml or
# Dockerfile that installs ffmpeg (see README).
#
# Cron schedule for checking due scheduled posts. Default: every 5 minutes.
SCHEDULER_CRON=*/5 * * * *

# --- Telegram scraper bot ---
# Lets you run /scrape <keyword> and /queue <url> from Telegram instead
# of opening the admin dashboard. Nothing auto-downloads — this only
# searches and organizes a review queue; you still download and upload
# videos yourself.
#
# 1. Message @BotFather on Telegram, /newbot, get your token.
# 2. Message your new bot once, then check
#    https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat id
#    (or use @userinfobot to get your own chat id quickly).
# 3. Set both vars below, deploy, then hit this once to register the
#    webhook (replace with your real domain):
#    GET https://riolendel.com/api/admin/telegram/set-webhook?token=YOUR_ADMIN_TOKEN&url=https://riolendel.com/api/telegram/webhook
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional — enables real auto-search for /scrape instead of manual
# search links. Get a free-tier key at https://serper.dev (Google Search
# results via API, ~$0.001/search after free credits).
SEARCH_API_KEY=

# --- Opt-in nurture sequence (email + SMS) ---
# Powers: (1) the welcome drip after someone signs up on the landing
# page or gets CSV-imported (PDF email → care tips → shop nudge, plus
# an SMS welcome), and (2) the existing price-move alerts in
# priceAlerts.js. Admin dashboard: /admin/contacts.html
#
# RESEND (email) — sign up at resend.com, verify riolendel.com as a
# sending domain (adds a few DNS records), generate an API key.
# This is for PERMISSION-BASED email only (people who opted in) — see
# the README section "Resend vs Smartlead.ai" if you're also
# considering cold outreach to non-opted-in contacts; that's a
# different tool for a different job.
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@riolendel.com

# SEMAPHORE (SMS, Philippines) — sign up at semaphore.co, load SMS
# credits, get your API key from the dashboard.
SEMAPHORE_API_KEY=
# Optional — a registered Sender Name (e.g. "RIOLENDEL") instead of
# Semaphore's shared default. Takes a few days for Semaphore to approve.
SEMAPHORE_SENDER_NAME=

# Used inside nurture emails to build links (PDF, /shop, etc).
SITE_URL=https://riolendel.com

# Cron schedule for checking due nurture-sequence messages. Default:
# every 10 minutes.
SEQUENCE_CRON=*/10 * * * *
